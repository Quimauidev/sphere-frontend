<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sphere.Views.Pages.ResetPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="ResetPasswordPage">
    <VerticalStackLayout Padding="30" Spacing="20">

        <Label
            Margin="0,20,0,0"
            FontAttributes="Bold"
            FontSize="28"
            HorizontalOptions="Center"
            Text="Khôi phục mật khẩu"
            TextColor="#222" />

        <Label
            FontSize="15"
            HorizontalTextAlignment="Center"
            Text="Nhập mã xác minh đã gửi cho bạn và tạo mật khẩu mới."
            TextColor="#666" />

        <!--  OTP  -->
        <Entry
            x:Name="txtOtp"
            Keyboard="Numeric"
            MaxLength="6"
            Placeholder="Mã OTP" />

        <!--  New Password  -->
        <Entry
            x:Name="txtNewPass"
            IsPassword="True"
            MaxLength="50"
            Placeholder="Mật khẩu mới" />

        <!--  Confirm Password  -->
        <Entry
            x:Name="txtConfirmPass"
            IsPassword="True"
            MaxLength="50"
            Placeholder="Xác nhận mật khẩu" />

        <!--  Submit  -->
        <Button
            BackgroundColor="#10B981"
            CornerRadius="5"
            FontAttributes="Bold"
            Text="Đổi mật khẩu" />

    </VerticalStackLayout>
</ContentPage>