<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sphere.Views.Pages.FilterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="FilterPage">
    <VerticalStackLayout Padding="20" Spacing="16">

        <!--  Chọn giới tính  -->
        <Label FontAttributes="Bold" Text="Giới tính:" />
        <Picker ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding SelectedGender}" />

        <!--  Khoảng cách  -->
        <Label FontAttributes="Bold" Text="Khoảng cách (km):" />
        <Slider
            Maximum="50"
            Minimum="1"
            Value="{Binding Distance}" />
        <Label Text="{Binding Distance, StringFormat='{}{0:F1} km'}" />

        <!--  Bật/tắt location  -->
        <HorizontalStackLayout>
            <Label Text="Bật định vị" VerticalOptions="Center" />
            <Switch IsToggled="{Binding IsLocationEnabled}" />
        </HorizontalStackLayout>

        <!--  Nút hành động  -->
        <Button Command="{Binding ApplyCommand}" Text="Áp dụng" />

        <Button Command="{Binding CancelCommand}" Text="Hủy" />
    </VerticalStackLayout>
</ContentPage>