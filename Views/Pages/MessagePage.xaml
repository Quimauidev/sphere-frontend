<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sphere.Views.Pages.MessagePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Sphere.Converters"
    Title="MessagePage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:FailedStatusToBoolConverter x:Key="FailedStatusToBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid BackgroundColor="White" RowDefinitions="Auto,*,Auto">
        <!--  🔹 Header: Avatar + Tên  -->
        <Grid
            Grid.Row="0"
            Padding="10,5,10,5"
            BackgroundColor="#f5f5f5"
            ColumnDefinitions="Auto,*, Auto"
            HeightRequest="56"
            VerticalOptions="Center">

            <!--  Avatar  -->
            <Border
                Padding="0"
                BackgroundColor="LightGray"
                HeightRequest="40"
                StrokeShape="20"
                WidthRequest="40">
                <Image Aspect="AspectFill" Source="{Binding PartnerAvatar}" />
            </Border>

            <!--  Full name  -->
            <Label
                Grid.Column="1"
                Margin="10,0,0,0"
                FontAttributes="Bold"
                FontSize="16"
                Text="{Binding PartnerFullName}"
                TextColor="Black"
                VerticalOptions="Center" />
            <!--  Action buttons  -->
            <HorizontalStackLayout
                Grid.Column="2"
                HorizontalOptions="End"
                Spacing="15"
                VerticalOptions="Center">

                <!--  Gọi thoại  -->
                <ImageButton
                    BackgroundColor="Transparent"
                    HeightRequest="24"
                    WidthRequest="24">
                    <ImageButton.Source>
                        <FontImageSource
                            FontFamily="MaterialIcons"
                            Glyph="&#xF03F2;"
                            Size="24"
                            Color="#512BD4" />
                    </ImageButton.Source>
                </ImageButton>

                <!--  Gọi video  -->
                <ImageButton
                    BackgroundColor="Transparent"
                    HeightRequest="24"
                    WidthRequest="24">
                    <ImageButton.Source>
                        <FontImageSource
                            FontFamily="MaterialIcons"
                            Glyph="&#xF0567;"
                            Size="24"
                            Color="#512BD4" />
                    </ImageButton.Source>
                </ImageButton>

                <!--  Báo cáo  -->
                <ImageButton
                    BackgroundColor="Transparent"
                    HeightRequest="24"
                    WidthRequest="24">
                    <ImageButton.Source>
                        <FontImageSource
                            FontFamily="MaterialIcons"
                            Glyph="&#xF07C4;"
                            Size="24"
                            Color="#512BD4" />
                    </ImageButton.Source>
                </ImageButton>
            </HorizontalStackLayout>
        </Grid>
        <!--  Danh sách tin nhắn  -->
        <CollectionView
            x:Name="MessagesList"
            Grid.Row="1"
            Margin="24,0,10,10"
            IsGrouped="False"
            ItemsSource="{Binding Messages}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreMessagesCommand}"
            SelectionMode="None"
            VerticalOptions="Fill">
            <!--  Đặt khoảng cách giữa item  -->
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="2" Orientation="Vertical" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid HorizontalOptions="{Binding IsMine, Converter={StaticResource BoolToLayoutOptionsConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                        </Grid.ColumnDefinitions>

                        <!--  Bubble tin nhắn  -->
                        <Border
                            Grid.Column="0"
                            Padding="10"
                            BackgroundColor="{Binding IsMine, Converter={StaticResource BoolToColorConverter}}"
                            MaximumWidthRequest="250"
                            Stroke="Transparent">
                            <Label Text="{Binding Content}" TextColor="{Binding IsMine, Converter={StaticResource BoolToTextColorConverter}}" />
                        </Border>

                        <!--  ActivityIndicator cho trạng thái Sending  -->
                        <ActivityIndicator
                            Grid.Column="1"
                            Margin="2,0,0,0"
                            HeightRequest="14"
                            IsRunning="{Binding IsSending}"
                            IsVisible="{Binding IsSending}"
                            VerticalOptions="End"
                            WidthRequest="14"
                            Color="DodgerBlue" />
                        <!--  Icon trạng thái Sent/Delivered/Seen  -->
                        <Label
                            Grid.Column="1"
                            Margin="2,0,0,0"
                            FontAttributes="Bold"
                            FontFamily="MaterialIcons"
                            HorizontalTextAlignment="Center"
                            IsVisible="{Binding ShowStatusIcon}"
                            Text="{Binding StatusIcon}"
                            TextColor="DodgerBlue"
                            VerticalOptions="End" />
                        <!--  Icon lỗi (Failed)  -->
                        <Label
                            Grid.Column="1"
                            Margin="2,0,0,0"
                            FontAttributes="Bold"
                            FontFamily="MaterialIcons"
                            HorizontalTextAlignment="Center"
                            IsVisible="{Binding Status, Converter={StaticResource FailedStatusToBoolConverter}}"
                            Text="&#xF0159;"
                            TextColor="Red"
                            VerticalOptions="End">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RetrySendMessageCommand}" CommandParameter="{Binding .}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>


        <!--  Thanh nhập tin nhắn  -->
        <Grid
            x:Name="InputGrid"
            Grid.Row="2"
            Padding="10,5,10,10"
            ColumnDefinitions="Auto,Auto,*,Auto"
            ColumnSpacing="5"
            VerticalOptions="End">

            <!--  Nút vị trí  -->
            <ImageButton
                Margin="0,0,0,10"
                Command="{Binding SendLocationCommand}"
                HeightRequest="25"
                VerticalOptions="End"
                WidthRequest="25">
                <ImageButton.Source>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph="&#xF034E;"
                        Size="25"
                        Color="#512BD4" />
                </ImageButton.Source>
            </ImageButton>

            <!--  Nút bộ sưu tập  -->
            <ImageButton
                Grid.Column="1"
                Margin="0,0,0,10"
                Command="{Binding OpenGalleryCommand}"
                HeightRequest="25"
                VerticalOptions="End"
                WidthRequest="25">
                <ImageButton.Source>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph="&#xF02F9;"
                        Size="25"
                        Color="#512BD4" />
                </ImageButton.Source>
            </ImageButton>

            <!--  Ô nhập  -->
            <Border
                Grid.Column="2"
                Padding="2,0,0,0"
                BackgroundColor="#f5f5f5"
                Stroke="#f5f5f5"
                StrokeShape="5">
                <Editor
                    x:Name="MessageEntry"
                    AutoSize="TextChanges"
                    Keyboard="Text"
                    MaxLength="1000"
                    MaximumHeightRequest="120"
                    Placeholder="Soạn tin nhắn..."
                    Text="{Binding CurrentMessage, Mode=TwoWay}" />
            </Border>

            <!--  Nút stack (đính kèm)  -->
            <ImageButton
                Grid.Column="3"
                Margin="0,0,0,10"
                Command="{Binding AttachCommand}"
                HeightRequest="25"
                IsVisible="{Binding CurrentMessage, Converter={StaticResource StringIsNullOrEmptyToBoolConverter}}"
                VerticalOptions="End"
                WidthRequest="25">
                <ImageButton.Source>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph="&#xF0C68;"
                        Size="25"
                        Color="#512BD4" />
                </ImageButton.Source>
            </ImageButton>

            <!--  Nút gửi  -->
            <ImageButton
                Grid.Column="3"
                Margin="0,0,0,10"
                Command="{Binding SendMessageCommand}"
                HeightRequest="25"
                IsVisible="{Binding CurrentMessage, Converter={StaticResource StringIsNotNullOrEmptyToBoolConverter}}"
                VerticalOptions="End"
                WidthRequest="25">
                <ImageButton.Source>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph="&#xF1C4D;"
                        Color="#512BD4" />
                </ImageButton.Source>
            </ImageButton>
        </Grid>
    </Grid>
</ContentPage>