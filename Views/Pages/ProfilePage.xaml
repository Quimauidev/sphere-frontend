<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sphere.Views.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:local="clr-namespace:Sphere.Views.Controls">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding EditProfileCommand}" Order="Primary">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialIcons"
                    Glyph="&#xF03EB;"
                    Size="24"
                    Color="Blue" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <Grid RowDefinitions="Auto, *">


        <CollectionView
            Footer="{Binding DiaryListVM.FooterKey}"
            ItemsSource="{Binding DiaryListVM.Diaries}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding DiaryListVM.LoadMoreDiariesCommand}"
            SelectionMode="None">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.Header>
                <local:ProfileHeaderView />
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <local:DiaryItemView />
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.FooterTemplate>
                <DataTemplate>
                    <Grid Padding="20" RowSpacing="10">
                        <ActivityIndicator
                            Margin="0,0,0,20"
                            HeightRequest="30"
                            HorizontalOptions="Center"
                            IsRunning="{Binding DiaryListVM.IsDiaryLoading}"
                            IsVisible="{Binding DiaryListVM.IsDiaryLoading}"
                            VerticalOptions="Center"
                            WidthRequest="30" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Text="__ Hết __"
                            TextColor="Gray"
                            VerticalOptions="Center">
                            <Label.IsVisible>
                                <MultiBinding Converter="{StaticResource ShowEndOfListConverter}">
                                    <Binding Path="BindingContext.DiaryListVM.HasNoMoreData" Source="{RelativeSource AncestorType={x:Type ContentPage}}" />
                                    <Binding Path="BindingContext.DiaryListVM.IsDiaryLoading" Source="{RelativeSource AncestorType={x:Type ContentPage}}" />
                                    <Binding Path="BindingContext.DiaryListVM.HasAnyData" Source="{RelativeSource AncestorType={x:Type ContentPage}}" />
                                </MultiBinding>
                            </Label.IsVisible>
                        </Label>
                    </Grid>
                </DataTemplate>
            </CollectionView.FooterTemplate>
        </CollectionView>
        <!--  Error nếu lỗi API  -->
        <!--  Frame thông báo lỗi chồng lên CollectionView  -->


        <StackLayout
            Margin="10"
            IsVisible="{Binding DiaryListVM.ErrorMessage}"
            Spacing="20"
            VerticalOptions="End">
            <Label
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                Text="{Binding DiaryListVM.ErrorMessage}"
                TextColor="DarkRed" />
            <Button
                Command="{Binding DiaryListVM.RetryCommand}"
                CornerRadius="5"
                HeightRequest="40"
                HorizontalOptions="Center"
                Text="Thử lại" />
        </StackLayout>

    </Grid>
</ContentPage>