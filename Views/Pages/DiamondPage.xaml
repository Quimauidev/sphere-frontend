<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sphere.Views.Pages.DiamondPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="PageRoot"
    Title="Nạp Kim Cương">
    <RefreshView Command="{Binding RefreshPackagesCommand}" IsRefreshing="{Binding IsRefreshing}">
        <VerticalStackLayout Padding="10" Spacing="20">

            <!--  Header tổng kim cương  -->
            <Border
                Padding="0"
                BackgroundColor="#f0f7ff"
                StrokeShape="8">

                <Label
                    FontAttributes="Bold"
                    FontSize="30"
                    HorizontalOptions="Center"
                    Text="{Binding Coins, StringFormat='{0:N0} 💎'}"
                    TextColor="#1877F2" />
            </Border>

            <!--  Tiêu đề  -->
            <Label
                FontAttributes="Bold"
                FontSize="22"
                HorizontalOptions="Center"
                Text="Các gói nạp"
                TextColor="#222" />
            <!--  RefreshView bọc CollectionView  -->

            <!--  Danh sách các gói nạp  -->
            <CollectionView ItemsSource="{Binding Packages}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="2"
                            Padding="5"
                            BackgroundColor="White"
                            StrokeShape="10">
                            <VerticalStackLayout Spacing="5">

                                <Label
                                    FontAttributes="Bold"
                                    FontSize="18"
                                    HorizontalOptions="Center"
                                    Text="{Binding Coins, StringFormat='{0} 💎'}" />

                                <Label
                                    HorizontalOptions="Center"
                                    Text="{Binding Price, StringFormat='{0:N0} VND'}"
                                    TextColor="#1877F2" />

                                <Button
                                    BackgroundColor="#1877F2"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectPackageCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="25"
                                    FontAttributes="Bold"
                                    MaximumHeightRequest="40"
                                    Text="Nạp ngay" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
