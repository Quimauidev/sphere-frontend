<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sphere.Views.Pages.MessageListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Tin nhắn">

    <StackLayout>
        <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
            <CollectionView
                ItemsSource="{Binding Conversations}"
                SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10" ColumnDefinitions="Auto,*,Auto">
                            <Frame
                                Padding="0"
                                BackgroundColor="#eee"
                                CornerRadius="24"
                                HasShadow="False"
                                HeightRequest="48"
                                WidthRequest="48">
                                <Image Aspect="AspectFill" Source="{Binding PartnerAvatar}" />
                            </Frame>
                            <StackLayout
                                Grid.Column="1"
                                Padding="10,0"
                                VerticalOptions="Center">
                                <Label FontAttributes="Bold" Text="{Binding PartnerName}" />
                                <Label
                                    FontSize="12"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding LastMessage}"
                                    TextColor="#666" />
                            </StackLayout>
                            <Label
                                Grid.Column="2"
                                FontSize="11"
                                Text="{Binding LastUpdatedText}"
                                TextColor="#999"
                                VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </StackLayout>
</ContentPage>