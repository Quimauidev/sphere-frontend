<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Sphere.Views.Pages.NearbyPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Sphere.Converters"
    Title="Lân cận">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding FilterCommand}" Order="Primary">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialIcons"
                    Glyph="&#xF10E6;"
                    Size="24"
                    Color="#512BD4" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <Grid Padding="10,0,10,0" RowDefinitions="Auto,*">
        <!--  Nút bật / tắt vị trí  -->
        <StackLayout
            HorizontalOptions="End"
            Orientation="Horizontal"
            Spacing="20">
            <Label Text="Bật vị trí" VerticalOptions="Center" />
            <Switch IsToggled="{Binding IsLocationEnabled}" />
        </StackLayout>

        <!--  Nội dung khi switch tắt  -->
        <StackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            IsVisible="{Binding IsLocationEnabled, Converter={StaticResource InverseBoolConverter}}"
            Spacing="30"
            VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="16"
                HorizontalTextAlignment="Center"
                Text="Hãy bật vị trí để tìm bạn bè lân cận" />
        </StackLayout>

        <!--  Loading  -->
        <ActivityIndicator
            Grid.Row="1"
            HeightRequest="40"
            HorizontalOptions="Center"
            IsRunning="True">
            <ActivityIndicator.IsVisible>
                <MultiBinding Converter="{StaticResource NearbyItemVisibilityConverter}" ConverterParameter="Loading">
                    <Binding Path="IsLocationEnabled" />
                    <Binding Path="UiState" />
                </MultiBinding>
            </ActivityIndicator.IsVisible>
        </ActivityIndicator>

        <!--  Error  -->
        <StackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="30"
            VerticalOptions="Center">
            <StackLayout.IsVisible>
                <MultiBinding Converter="{StaticResource NearbyItemVisibilityConverter}" ConverterParameter="Error">
                    <Binding Path="IsLocationEnabled" />
                    <Binding Path="UiState" />
                </MultiBinding>
            </StackLayout.IsVisible>

            <Label
                FontAttributes="Bold"
                FontSize="16"
                HorizontalTextAlignment="Center"
                Text="{Binding ErrorMessage}"
                TextColor="Red" />
            <Button
                Command="{Binding LoadFirstNearbyCommand}"
                Text="Thử lại"
                WidthRequest="100" />
        </StackLayout>

        <!--  Empty  -->
        <StackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="30"
            VerticalOptions="Center">
            <StackLayout.IsVisible>
                <MultiBinding Converter="{StaticResource NearbyItemVisibilityConverter}" ConverterParameter="Empty">
                    <Binding Path="IsLocationEnabled" />
                    <Binding Path="UiState" />
                </MultiBinding>
            </StackLayout.IsVisible>

            <Label
                FontAttributes="Bold"
                FontSize="16"
                HorizontalTextAlignment="Center"
                Text="Không có người dùng nào gần bạn." />
            <Button
                Command="{Binding LoadFirstNearbyCommand}"
                Text="Thử lại"
                WidthRequest="100" />
        </StackLayout>

        <!--  Success / danh sách Nearby  -->
        <RefreshView
            Grid.Row="1"
            Command="{Binding RefreshNearbyCommand}"
            IsRefreshing="{Binding IsRefreshing}">
            <RefreshView.IsVisible>
                <MultiBinding Converter="{StaticResource NearbyItemVisibilityConverter}" ConverterParameter="Success">
                    <Binding Path="IsLocationEnabled" />
                    <Binding Path="UiState" />
                </MultiBinding>
            </RefreshView.IsVisible>

            <CollectionView
                x:Name="NearbyList"
                ItemsSource="{Binding Nearby}"
                RemainingItemsThreshold="3"
                RemainingItemsThresholdReachedCommand="{Binding LoadMoreNearbyCommand}"
                SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="5"
                            Stroke="#ac99ea"
                            StrokeShape="5">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                <Border
                                    HeightRequest="50"
                                    StrokeShape="RoundRectangle 25"
                                    StrokeThickness="0"
                                    WidthRequest="50">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenProfileCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Image Aspect="AspectFill" Source="{Binding AvatarDisplay}" />
                                </Border>

                                <StackLayout
                                    Grid.Column="1"
                                    Orientation="Vertical"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"
                                        Text="{Binding FullName}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenProfileCommand}" CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label
                                        FontSize="12"
                                        Text="{Binding DistanceDisplay}"
                                        TextColor="DodgerBlue" />
                                </StackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding Age}"
                                    TextColor="{Binding Gender, Converter={StaticResource GenderToColorConverter}}"
                                    VerticalOptions="Center" />

                                <StackLayout
                                    Grid.Column="3"
                                    HeightRequest="40"
                                    Orientation="Horizontal"
                                    Spacing="5"
                                    VerticalOptions="Center">
                                    <Button
                                        Padding="0"
                                        BackgroundColor="#5795ea"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FollowCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="20"
                                        FontSize="12"
                                        IsVisible="{Binding IsFollowing, Converter={StaticResource InverseBoolConverter}}"
                                        MaximumHeightRequest="30"
                                        MinimumWidthRequest="60"
                                        Text="Theo dõi"
                                        TextColor="White" />
                                    <Button
                                        Padding="0"
                                        BackgroundColor="#e357ea"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChatCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="20"
                                        FontSize="12"
                                        MaximumHeightRequest="30"
                                        MinimumWidthRequest="60"
                                        Text="Nhắn tin"
                                        TextColor="White" />
                                </StackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <ActivityIndicator
                        Margin="10"
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsLoadingMore}"
                        IsVisible="{Binding IsLoadingMore}" />
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>