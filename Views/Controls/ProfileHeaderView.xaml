<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Sphere.Views.Controls.ProfileHeaderView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Spacing="5">
        <Grid>
            <Image
                Aspect="AspectFill"
                HeightRequest="100"
                Source="{Binding CoverPhotoDisplay}"
                VerticalOptions="Start">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ShowImageOptionsCommand}" CommandParameter="cover" />
                </Image.GestureRecognizers>
            </Image>
            <StackLayout
                Margin="0,30,0,0"
                HorizontalOptions="Center"
                Spacing="5">

                <Frame
                    Padding="0"
                    BorderColor="White"
                    CornerRadius="50"
                    HeightRequest="100"
                    WidthRequest="100">
                    <Image
                        x:Name="AvatarImage"
                        Aspect="AspectFill"
                        Source="{Binding AvatarDisplay}">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowImageOptionsCommand}" CommandParameter="avatar" />
                        </Image.GestureRecognizers>
                    </Image>
                </Frame>

                <StackLayout
                    HorizontalOptions="End"
                    Orientation="Horizontal"
                    Spacing="5">
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        Text="{Binding FullNameDisplay}" />

                    <Label
                        FontAttributes="Bold"
                        FontFamily="MaterialIcons"
                        FontSize="14"
                        Text="{Binding CurrentUser.UserDTO.Gender, Converter={StaticResource GenderToIconConverter}}"
                        TextColor="{Binding CurrentUser.UserDTO.Gender, Converter={StaticResource GenderToColorConverter}}"
                        VerticalOptions="Center" />
                </StackLayout>

            </StackLayout>
        </Grid>
        <VerticalStackLayout HorizontalOptions="Center">
            <HorizontalStackLayout Spacing="10">
                <Label Text="{Binding CurrentUser.UserDTO.UserIdNumber, StringFormat='ID: {0}'}" TextColor="#666" />
                <ImageButton HeightRequest="18" WidthRequest="18">
                    <ImageButton.Source>
                        <FontImageSource
                            FontFamily="MaterialIcons"
                            Glyph="&#xF018F;"
                            Color="#666" />
                    </ImageButton.Source>
                </ImageButton>
            </HorizontalStackLayout>
            <!--  Ngày sinh  -->
            <HorizontalStackLayout>
                <Label Text="Ngày sinh: " />
                <Label Text="{Binding BirthDayDisplay}" />
            </HorizontalStackLayout>

            <!--  Giới tính  -->
            <HorizontalStackLayout>
                <Label Text="Giới tính: " />
                <Label Text="{Binding GenderDisplay}" />
            </HorizontalStackLayout>

            <!--  Ngày tham gia  -->
            <HorizontalStackLayout>
                <Label Text="Tham gia: " />
                <Label Text="{Binding CreatedAtDisplay}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
        <HorizontalStackLayout Padding="0" HorizontalOptions="Center">
            <!--  Frame Kim Cương  -->
            <Frame
                Padding="0"
                BackgroundColor="White"
                BorderColor="#DADADA"
                CornerRadius="20"
                HasShadow="True"
                HeightRequest="40"
                WidthRequest="150">

                <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="30"
                    VerticalOptions="Center">

                    <!--  Icon Kim Cương  -->
                    <Image
                        HeightRequest="30"
                        Source="kimcuong.png"
                        VerticalOptions="Center"
                        WidthRequest="30" />

                    <!--  Số Kim Cương  -->
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="{Binding Coins, Converter={StaticResource CoinsFormatterConverter}}"
                        TextColor="#1877F2"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ManageCoinsCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!--  Nút Hành động / Icon thêm  -->
                    <Frame
                        Padding="5"
                        BackgroundColor="#E5F0FF"
                        CornerRadius="15"
                        HasShadow="False"
                        VerticalOptions="Center">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ManageCoinsCommand}" />
                        </Frame.GestureRecognizers>
                        <Image HeightRequest="20" WidthRequest="20">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="MaterialIcons"
                                    Glyph="&#xF11EC;"
                                    Color="#1877F2" />
                            </Image.Source>
                        </Image>
                    </Frame>

                </HorizontalStackLayout>
            </Frame>
        </HorizontalStackLayout>

        <HorizontalStackLayout
            Padding="5"
            HorizontalOptions="Center"
            Spacing="10">

            <!--  Nút Theo dõi  -->
            <Frame
                Padding="10"
                BackgroundColor="#1DA1F2"
                CornerRadius="20"
                HorizontalOptions="Center">
                <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="8"
                    VerticalOptions="Center">
                    <Image HeightRequest="20" WidthRequest="20">
                        <Image.Source>
                            <FontImageSource
                                FontFamily="MaterialIcons"
                                Glyph="&#xF11EC;"
                                Color="White" />
                        </Image.Source>
                    </Image>
                    <Label
                        FontAttributes="Bold"
                        Text="Theo dõi"
                        TextColor="White" />
                </HorizontalStackLayout>
            </Frame>

            <!--  Nút Nhắn tin  -->
            <Frame
                Padding="10"
                BackgroundColor="White"
                BorderColor="#1DA1F2"
                CornerRadius="20"
                HorizontalOptions="Center">
                <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="8"
                    VerticalOptions="Center">
                    <Image HeightRequest="20" WidthRequest="20">
                        <Image.Source>
                            <FontImageSource
                                FontFamily="MaterialIcons"
                                Glyph="&#xF020E;"
                                Color="#1DA1F2" />
                        </Image.Source>
                    </Image>
                    <Label
                        FontAttributes="Bold"
                        Text="Nhắn tin"
                        TextColor="#1DA1F2" />
                </HorizontalStackLayout>
            </Frame>

        </HorizontalStackLayout>


        <Grid Padding="10" ColumnDefinitions="Auto,Auto,Auto">
            <Label FontAttributes="Bold" Text="Tiểu sử: " />
            <VerticalStackLayout Grid.Column="1">
                <Label
                    x:Name="BioLabel"
                    LineBreakMode="WordWrap"
                    MaxLines="{Binding BioMaxLines}"
                    Text="{Binding BioDisplay}"
                    VerticalOptions="Fill"
                    WidthRequest="250">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditBioCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <!--  Nút xem thêm/thu gọn  -->
                <Label
                    FontAttributes="Italic"
                    IsVisible="{Binding ShouldShowBioToggle}"
                    Text="{Binding BioToggleText}"
                    TextColor="Blue">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleBioCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
            <ImageButton
                Grid.Column="2"
                Command="{Binding EditBioCommand}"
                HeightRequest="18"
                VerticalOptions="Start"
                WidthRequest="18">
                <ImageButton.Source>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph="&#xF03EB;"
                        Color="Blue" />
                </ImageButton.Source>
            </ImageButton>
        </Grid>
        <BoxView BackgroundColor="LightGray" HeightRequest="2" />
        <Frame
            Margin="10"
            Padding="0"
            BorderColor="LightGray"
            HasShadow="True">
            <Editor
                Margin="5"
                IsReadOnly="True"
                Placeholder="Đăng bài viết">
                <Editor.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PostStatusCommand}" />
                </Editor.GestureRecognizers>
            </Editor>
        </Frame>
    </VerticalStackLayout>
</ContentView>
