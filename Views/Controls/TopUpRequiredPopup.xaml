<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="Sphere.Views.Controls.TopUpRequiredPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
    Size="320,180">

    <VerticalStackLayout Padding="20" Spacing="16">
        <Label FontAttributes="Bold" Text="Không đủ kim cương" />
        <Label HorizontalOptions="Center" Text="Bạn cần nạp thêm kim cương để mở khóa cuộc trò chuyện này" />
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
            <Button
                x:Name="CloseButton"
                Clicked="OnClose"
                Text="Đóng"
                WidthRequest="120" />
            <Button
                x:Name="TopUpButton"
                Clicked="OnTopUp"
                Text="Nạp kim cương"
                WidthRequest="120" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</toolkit:Popup>
